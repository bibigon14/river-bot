[Unit]
Description=RiverBot - Telegram bot with USGS river data
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Замените "pi" на ваше имя пользователя, если оно другое
User=pi
WorkingDirectory=/home/pi/riverbot
ExecStart=/home/pi/riverbot/venv/bin/python /home/pi/riverbot/bot.py
Restart=on-failure
RestartSec=15
StandardOutput=append:/home/pi/riverbot/riverbot.log
StandardError=append:/home/pi/riverbot/riverbot.log

[Install]
WantedBy=multi-user.target
